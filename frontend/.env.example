# API origin (no trailing slash).
# Production example: https://api.your-campus.edu
#
# Development: `.env.development` sets VITE_API_BASE_URL=http://localhost:5000 so the
# browser calls the API directly. Your backend must allow CORS from http://localhost:5173.
# To use the Vite proxy instead, remove VITE_API_BASE_URL from `.env.development` and
# rely on `VITE_DEV_PROXY_TARGET` below.
VITE_API_BASE_URL=

# Dev-only: Vite proxy target when you are NOT using VITE_API_BASE_URL (same-origin /api).
VITE_DEV_PROXY_TARGET=http://localhost:5000
